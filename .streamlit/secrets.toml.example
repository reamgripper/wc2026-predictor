# ─────────────────────────────────────────────────────────────────────────────
# EXAMPLE secrets file.  Copy to ".streamlit/secrets.toml" for local testing,
# or paste the contents into the Streamlit Community Cloud "Secrets" editor.
#
# Generate real entries with:  python make_users.py
# NEVER commit the real secrets.toml (it is .gitignored).
# ─────────────────────────────────────────────────────────────────────────────

[auth]
cookie_name = "wc2026_auth"
cookie_key = "REPLACE_WITH_A_RANDOM_HEX_STRING"   # e.g. python -c "import secrets;print(secrets.token_hex(16))"
cookie_expiry_days = 7

# One block per user. The password MUST be a bcrypt hash (make_users.py prints these).
[auth.credentials.usernames.alice]
name = "Alice Example"
email = "alice@example.com"
password = "$2b$12$REPLACE_WITH_A_REAL_BCRYPT_HASH_FROM_make_users_py"

[auth.credentials.usernames.bob]
name = "Bob Example"
email = "bob@example.com"
password = "$2b$12$REPLACE_WITH_A_REAL_BCRYPT_HASH_FROM_make_users_py"
